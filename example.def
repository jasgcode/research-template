Bootstrap: docker
From: nvidia/cuda:12.6.1-base-ubuntu24.04

%files
    pyproject.toml /app/pyproject.toml

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y --no-install-recommends \
        python3.12 \
        python3.12-venv \
        python3-pip \
        curl \
        git \
        libglib2.0-0 \
        libsm6 \
        libxrender1 \
        libxext6 \
        libfontconfig1 \
    && rm -rf /var/lib/apt/lists/*

    # Install uv — use the COPY method from their container image instead of
    # shell-script-with-fallback gymnastics
    curl -LsSf https://astral.sh/uv/install.sh | sh
    cp /root/.local/bin/uv /usr/local/bin/uv

    # Verify
    uv --version

    # Install Python deps into a fixed venv
    cd /app
    UV_PROJECT_ENVIRONMENT=/opt/venv uv sync --frozen --no-dev

    # Cleanup
    apt-get clean

%environment
    export UV_PROJECT_ENVIRONMENT="/opt/venv"
    export PATH="/opt/venv/bin:/usr/local/bin:$PATH"
    export LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH}"
    export PYTHONDONTWRITEBYTECODE=1

%runscript
    cd /app
    exec "$@"